---
import "../styles/global.css";

const { title = "FutScore Mundial 2026" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Calendario, marcadores, grupos, fases, estadios y detalles en vivo del Mundial de Futbol 2026."
    />
    <link rel="preconnect" href="https://site.api.espn.com" />
    <link rel="preconnect" href="https://a.espncdn.com" />
    <link rel="preconnect" href="https://worldcup26.ir" />
    <link rel="icon" href="/public/copa.png" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
