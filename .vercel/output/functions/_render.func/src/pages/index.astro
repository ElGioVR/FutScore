---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Icon from "@/components/Icon.astro";
---

<BaseLayout>
  <section
    id="ligamx-banner"
    class="ligamx-banner"
    data-minimized="false"
    aria-label="Proximamente Liga MX"
  >
    <div class="ligamx-banner-inner">
      <img class="ligamx-logo" src="/ligamx-logo.png" alt="" aria-hidden="true" />
      <div class="ligamx-copy">
        <span>Proximamente</span>
        <strong>Data de Liga MX</strong>
        <p>Calendario, marcadores y tablas de la liga mexicana se suman pronto a FutScore.</p>
      </div>
      <button
        id="ligamx-banner-toggle"
        class="ligamx-banner-toggle"
        type="button"
        aria-expanded="true"
        aria-controls="ligamx-banner"
      >
        Minimizar
      </button>
    </div>
  </section>

  <header class="topbar">
    <div class="topbar-inner">
      <a class="brand" href="/" aria-label="FutScore home">
        <Icon name="world-cup" size={42} />
        <span>FutScore</span>
      </a>

      <label class="search-shell" aria-label="Buscar seleccion">
        <span aria-hidden="true"
          ><Icon name="search" cls="inline-icon" size={16} /></span
        >
        <input id="search" type="search" placeholder="Buscar equipo" />
      </label>

      <button
        id="mobile-menu-toggle"
        class="mobile-menu-toggle"
        type="button"
        aria-label="Abrir menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" cls="inline-icon" size={22} />
      </button>

      <nav class="top-nav" aria-label="Principal">
        <a href="#matches" data-section-link="matches">Partidos</a>
        <a href="#bracket" data-section-link="bracket">Llave</a>
        <a href="#groups">Grupos</a>
        <a href="#match-detail">Detalle</a>
      </nav>

      <nav id="mobile-menu" class="mobile-menu" aria-label="Menu movil" hidden>
        <a href="#matches" data-section-link="matches">
          <Icon name="list" cls="inline-icon" size={18} />
          <span>Partidos</span>
        </a>
        <a href="#groups">
          <Icon name="table" cls="inline-icon" size={18} />
          <span>Grupos</span>
        </a>
        <a href="#bracket" data-section-link="bracket">
          <Icon name="git-branch" cls="inline-icon" size={18} />
          <span>Llave</span>
        </a>
        <a href="#match-detail">
          <Icon name="info" cls="inline-icon" size={18} />
          <span>Detalle</span>
        </a>
      </nav>
    </div>
  </header>

  <main class="score-layout">
    <aside class="left-rail">
      <section class="panel league-panel">
        <h2>FIFA World Cup</h2>
        <a class="league-link active" href="#matches" data-section-link="matches"
          ><span><Icon name="list" cls="inline-icon" size={16} /></span> Partidos</a
        >
        <a class="league-link" href="#groups"><span><Icon name="table" cls="inline-icon" size={16} /></span> Grupos</a>
        <a class="league-link" href="#bracket" data-section-link="bracket"><span><Icon name="git-branch" cls="inline-icon" size={16} /></span> Llave</a>
        <a class="league-link" href="#match-detail"
          ><span><Icon name="info" cls="inline-icon" size={16} /></span> Detalle seleccionado</a
        >
      </section>

      <section id="groups" class="panel standings-shell side-standings" aria-label="Grupos del Mundial">
        <div class="section-title">
          <div>
            <h2>FIFA World Cup</h2>
            <p>Grupos calculados</p>
          </div>
          <span>A-L</span>
        </div>
        <div class="standings-grid" data-groups-grid></div>
      </section>
    </aside>

    <section class="center-feed">
      <section class="panel date-card" data-filters-open="false">
        <div class="date-row">
          <button type="button" aria-label="Dia anterior"
            ><Icon name="chevron-left" cls="inline-icon" size={16} /></button
          >
          <strong>Mundial 2026</strong>
          <button type="button" aria-label="Dia siguiente"
            ><Icon name="chevron-right" cls="inline-icon" size={16} /></button
          >
        </div>
        <button
          id="filter-toggle"
          class="filter-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="match-filters"
        >
          <span>Filtros</span>
          <Icon name="chevron-down" cls="inline-icon" size={16} />
        </button>
        <div id="match-filters" class="filter-row">
          <button class="chip" data-view="live">En vivo</button>
          <button class="chip" data-view="today">Hoy</button>
          <button class="chip" data-view="all" data-active="true">Todos</button>
          <select id="group-filter" aria-label="Filtrar grupo">
            <option value="all">Todos los grupos</option>
          </select>
          <button
            id="refresh"
            class="refresh-btn"
            type="button"
            aria-label="Actualizar"
            ><Icon name="refresh" cls="inline-icon" size={16} /></button
          >
        </div>
      </section>

      <section id="matches" class="match-stack" aria-label="Partidos"></section>

      <section
        id="bracket"
        class="panel bracket-shell"
        aria-label="Llave de eliminacion directa"
        hidden
      >
        <div class="section-title">
          <div>
            <h2>Llave</h2>
            <p>Eliminacion directa</p>
          </div>
          <span>ESPN</span>
        </div>
        <div id="knockout-bracket" class="bracket-board"></div>
      </section>
    </section>

    <aside class="right-rail">
      <section class="panel detail-widget selected-match-widget">
        <div id="match-detail"></div>
      </section>

    </aside>

  </main>

  <footer class="site-footer">
    <div class="footer-main">
      <section class="footer-brand" aria-label="FutScore">
        <Icon name="world-cup" size={44} />
        <h2>FutScore</h2>
        <p>Calendario, grupos y llave del Mundial 2026.</p>
      </section>

      <nav class="footer-links" aria-label="Secciones de la app">
        <h2>Secciones</h2>
        <a href="#matches" data-section-link="matches">Partidos</a>
        <a href="#groups">Grupos</a>
        <a href="#bracket" data-section-link="bracket">Llave</a>
        <a href="#match-detail">Detalle seleccionado</a>
      </nav>

      <section class="footer-feed" aria-label="Estado del feed">
        <div>
          <div class="feed-title-row">
            <span class="feed-dot" aria-hidden="true"
              ><Icon name="dot" cls="feed-dot-icon" size={10} /></span
            >
            <h2>Feed ESPN</h2>
          </div>
          <p id="data-status">Preparando datos...</p>
        </div>
        <div class="source-pill">
          <small>Fuente</small>
          <span id="data-source">demo local</span>
          <time id="updated-at">--:--</time>
        </div>
      </section>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-inner">
        <span>Copyright 2026 FutScore</span>
        <span>Datos de partidos sujetos a disponibilidad del feed.</span>
      </div>
    </div>
  </footer>

  <script>
    import "../scripts/app.ts";
  </script>
</BaseLayout>
